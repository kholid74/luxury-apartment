---
import Layout from '../layouts/Layout.astro';
import { images } from '../data/images';
---

<Layout>
  <slot name="head">
    <title>Gallery — The Meridian Residences | Architecture &amp; Interiors</title>
    <meta name="description" content="Explore the visual narrative of The Meridian Residences — curated photography of architecture, interiors, amenities, and views from the heart of Kebayoran Baru." />
  </slot>

  <!-- Hero Mini -->
  <section class="pt-48 pb-24 bg-primary-black">
    <div class="container-standard text-center reveal">
      <p class="overline mb-4">Gallery</p>
      <h1 class="font-display text-5xl md:text-6xl font-bold text-primary-ivory leading-tight mb-6">
        Gallery
      </h1>
      <p class="text-lg md:text-xl text-neutral-300 max-w-2xl mx-auto leading-relaxed">
        A visual journey through The Meridian Residences — from the architectural expression of the façade to the
        considered interiors and curated amenities that define life at the address.
      </p>
    </div>
  </section>

  <!-- Filter Tabs -->
  <section class="bg-primary-black pt-0 pb-12">
    <div class="container-standard reveal">
      <div class="flex flex-wrap justify-center gap-4" role="tablist">
        <button class="btn btn-outline-gold btn-sm active" data-filter="all" role="tab" aria-selected="true">All</button>
        <button class="btn btn-outline-light btn-sm" data-filter="exteriors" role="tab" aria-selected="false">Exteriors</button>
        <button class="btn btn-outline-light btn-sm" data-filter="interiors" role="tab" aria-selected="false">Interiors</button>
        <button class="btn btn-outline-light btn-sm" data-filter="amenities" role="tab" aria-selected="false">Amenities</button>
        <button class="btn btn-outline-light btn-sm" data-filter="views" role="tab" aria-selected="false">Views</button>
      </div>
    </div>
  </section>

  <!-- Gallery Grid -->
  <section class="bg-primary-black pt-0">
    <div class="container-wide reveal">
      <div class="columns-1 sm:columns-2 lg:columns-3 gap-6 space-y-6" id="gallery-grid">
        <!-- 1. 16:9 -->
        <div class="break-inside-avoid bg-primary-midnight rounded-sm overflow-hidden cursor-pointer gallery-item" data-category="exteriors" data-caption="Exterior — Façade">
          <div class="aspect-video">
            <img src={images.gallery[0].src} alt={images.gallery[0].alt} class="w-full h-full object-cover" loading="lazy" />
          </div>
        </div>

        <!-- 2. 3:2 -->
        <div class="break-inside-avoid bg-primary-midnight rounded-sm overflow-hidden cursor-pointer gallery-item" data-category="interiors" data-caption="Living Room">
          <div class="aspect-[3/2]">
            <img src={images.gallery[1].src} alt={images.gallery[1].alt} class="w-full h-full object-cover" loading="lazy" />
          </div>
        </div>

        <!-- 3. 2:3 (portrait) -->
        <div class="break-inside-avoid bg-primary-midnight rounded-sm overflow-hidden cursor-pointer gallery-item" data-category="interiors" data-caption="Master Suite">
          <div class="aspect-[2/3]">
            <img src={images.gallery[2].src} alt={images.gallery[2].alt} class="w-full h-full object-cover" loading="lazy" />
          </div>
        </div>

        <!-- 4. 1:1 -->
        <div class="break-inside-avoid bg-primary-midnight rounded-sm overflow-hidden cursor-pointer gallery-item" data-category="amenities" data-caption="Sky Pool">
          <div class="aspect-square">
            <img src={images.gallery[3].src} alt={images.gallery[3].alt} class="w-full h-full object-cover" loading="lazy" />
          </div>
        </div>

        <!-- 5. 16:9 -->
        <div class="break-inside-avoid bg-primary-midnight rounded-sm overflow-hidden cursor-pointer gallery-item" data-category="views" data-caption="City View — Sunset">
          <div class="aspect-video">
            <img src={images.gallery[4].src} alt={images.gallery[4].alt} class="w-full h-full object-cover" loading="lazy" />
          </div>
        </div>

        <!-- 6. 3:2 -->
        <div class="break-inside-avoid bg-primary-midnight rounded-sm overflow-hidden cursor-pointer gallery-item" data-category="interiors" data-caption="Kitchen Detail">
          <div class="aspect-[3/2]">
            <img src={images.gallery[5].src} alt={images.gallery[5].alt} class="w-full h-full object-cover" loading="lazy" />
          </div>
        </div>

        <!-- 7. 1:1 -->
        <div class="break-inside-avoid bg-primary-midnight rounded-sm overflow-hidden cursor-pointer gallery-item" data-category="exteriors" data-caption="Entry Lobby">
          <div class="aspect-square">
            <img src={images.gallery[6].src} alt={images.gallery[6].alt} class="w-full h-full object-cover" loading="lazy" />
          </div>
        </div>

        <!-- 8. 2:3 (portrait) -->
        <div class="break-inside-avoid bg-primary-midnight rounded-sm overflow-hidden cursor-pointer gallery-item" data-category="interiors" data-caption="Bathroom Suite">
          <div class="aspect-[2/3]">
            <img src={images.gallery[7].src} alt={images.gallery[7].alt} class="w-full h-full object-cover" loading="lazy" />
          </div>
        </div>

        <!-- 9. 16:9 -->
        <div class="break-inside-avoid bg-primary-midnight rounded-sm overflow-hidden cursor-pointer gallery-item" data-category="amenities" data-caption="Private Cinema">
          <div class="aspect-video">
            <img src={images.gallery[8].src} alt={images.gallery[8].alt} class="w-full h-full object-cover" loading="lazy" />
          </div>
        </div>

        <!-- 10. 3:2 -->
        <div class="break-inside-avoid bg-primary-midnight rounded-sm overflow-hidden cursor-pointer gallery-item" data-category="views" data-caption="Rooftop Panorama">
          <div class="aspect-[3/2]">
            <img src={images.gallery[9].src} alt={images.gallery[9].alt} class="w-full h-full object-cover" loading="lazy" />
          </div>
        </div>

        <!-- 11. 1:1 -->
        <div class="break-inside-avoid bg-primary-midnight rounded-sm overflow-hidden cursor-pointer gallery-item" data-category="exteriors" data-caption="Landscaped Garden">
          <div class="aspect-square">
            <img src={images.gallery[10].src} alt={images.gallery[10].alt} class="w-full h-full object-cover" loading="lazy" />
          </div>
        </div>

        <!-- 12. 2:3 (portrait) -->
        <div class="break-inside-avoid bg-primary-midnight rounded-sm overflow-hidden cursor-pointer gallery-item" data-category="amenities" data-caption="Wellness Pavilion">
          <div class="aspect-[2/3]">
            <img src={images.gallery[11].src} alt={images.gallery[11].alt} class="w-full h-full object-cover" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Lightbox Overlay -->
  <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Image lightbox">
    <!-- Close button -->
    <button id="lightbox-close" class="absolute top-6 right-6 z-10 w-12 h-12 flex items-center justify-center text-primary-ivory hover:text-gold transition-colors duration-300" aria-label="Close lightbox">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
        <line x1="3" y1="3" x2="25" y2="25" stroke="currentColor" stroke-width="1.5"/>
        <line x1="25" y1="3" x2="3" y2="25" stroke="currentColor" stroke-width="1.5"/>
      </svg>
    </button>

    <!-- Previous arrow -->
    <button id="lightbox-prev" class="absolute left-4 md:left-8 z-10 w-12 h-12 flex items-center justify-center text-primary-ivory hover:text-gold transition-colors duration-300" aria-label="Previous image">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M18 4L8 14L18 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <!-- Next arrow -->
    <button id="lightbox-next" class="absolute right-4 md:right-8 z-10 w-12 h-12 flex items-center justify-center text-primary-ivory hover:text-gold transition-colors duration-300" aria-label="Next image">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M10 4L20 14L10 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <!-- Image container -->
    <div class="flex flex-col items-center justify-center w-full h-full px-16 md:px-24 py-20">
      <img id="lightbox-img" src="" alt="" class="max-w-[85vw] max-h-[70vh] object-contain" />
      <p id="lightbox-caption" class="text-primary-ivory text-lg md:text-xl mt-6 font-body text-center"></p>
      <p id="lightbox-counter" class="text-neutral-400 text-sm mt-2 font-body tracking-wider"></p>
    </div>
  </div>
</Layout>

<script>
  // ─── Gallery Filter Tabs ───
  const filterButtons = document.querySelectorAll('[data-filter]');
  const galleryItems = document.querySelectorAll('[data-category]');

  filterButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;

      // Update active button
      filterButtons.forEach((b) => {
        b.classList.remove('btn-outline-gold', 'active');
        b.classList.add('btn-outline-light');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.remove('btn-outline-light');
      btn.classList.add('btn-outline-gold', 'active');
      btn.setAttribute('aria-selected', 'true');

      // Filter items
      galleryItems.forEach((item) => {
        if (filter === 'all' || item.dataset.category === filter) {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });
    });
  });

  // ─── Lightbox ───
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');
  const lightboxCaption = document.getElementById('lightbox-caption');
  const lightboxCounter = document.getElementById('lightbox-counter');
  const lightboxClose = document.getElementById('lightbox-close');
  const lightboxPrev = document.getElementById('lightbox-prev');
  const lightboxNext = document.getElementById('lightbox-next');

  let currentIndex = 0;
  let visibleItems = [];

  function getVisibleGalleryItems() {
    // Get all gallery-item elements that are currently visible (not display:none)
    const allItems = document.querySelectorAll('.gallery-item');
    return Array.from(allItems).filter((item) => item.style.display !== 'none');
  }

  function openLightbox(index) {
    visibleItems = getVisibleGalleryItems();
    if (visibleItems.length === 0) return;

    currentIndex = Math.max(0, Math.min(index, visibleItems.length - 1));
    updateLightboxContent();
    lightbox.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.remove('open');
    document.body.style.overflow = '';
  }

  function updateLightboxContent() {
    const item = visibleItems[currentIndex];
    if (!item) return;

    const caption = item.dataset.caption || '';
    lightboxCaption.textContent = caption;
    lightboxCounter.textContent = `${currentIndex + 1} / ${visibleItems.length}`;

    // If the item contains an actual <img>, use its src; otherwise keep placeholder
    const imgEl = item.querySelector('img');
    if (imgEl && imgEl.src) {
      lightboxImg.src = imgEl.src;
      lightboxImg.alt = caption;
    } else {
      // No real image yet — show a blank state or keep current
      lightboxImg.src = '';
      lightboxImg.alt = caption;
    }
  }

  function showPrev() {
    if (visibleItems.length === 0) return;
    currentIndex = (currentIndex - 1 + visibleItems.length) % visibleItems.length;
    updateLightboxContent();
  }

  function showNext() {
    if (visibleItems.length === 0) return;
    currentIndex = (currentIndex + 1) % visibleItems.length;
    updateLightboxContent();
  }

  // Click handler on gallery items
  document.querySelectorAll('.gallery-item').forEach((item, index) => {
    item.addEventListener('click', () => {
      // Find this item's index among currently visible items
      visibleItems = getVisibleGalleryItems();
      const idx = visibleItems.indexOf(item);
      openLightbox(idx >= 0 ? idx : 0);
    });
  });

  // Close button
  lightboxClose.addEventListener('click', closeLightbox);

  // Click outside image to close
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) {
      closeLightbox();
    }
  });

  // Arrow navigation
  lightboxPrev.addEventListener('click', (e) => {
    e.stopPropagation();
    showPrev();
  });

  lightboxNext.addEventListener('click', (e) => {
    e.stopPropagation();
    showNext();
  });

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('open')) return;

    switch (e.key) {
      case 'Escape':
        closeLightbox();
        break;
      case 'ArrowLeft':
        showPrev();
        break;
      case 'ArrowRight':
        showNext();
        break;
    }
  });
</script>
