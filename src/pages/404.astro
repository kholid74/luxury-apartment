---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <slot name="head">
    <title>404 — Page Not Found | The Meridian Residences</title>
    <meta name="description" content="The page you are looking for could not be found." />
  </slot>

  <section class="pt-48 pb-24 bg-primary-black min-h-screen flex items-center">
    <div class="container-standard text-center reveal">
      <p class="font-display text-[12rem] md:text-[16rem] font-bold text-gold leading-none mb-0 select-none">
        404
      </p>
      <p class="overline mb-6"><span class="lang-en">Page Not Found</span><span class="lang-id">Halaman Tidak Ditemukan</span></p>
      <h1 class="font-display text-3xl md:text-4xl font-bold text-primary-ivory mb-6">
        <span class="lang-en">The Page You Seek Does Not Exist</span><span class="lang-id">Halaman yang Anda Cari Tidak Ditemukan</span>
      </h1>
      <p class="text-lg text-neutral-300 max-w-lg mx-auto mb-12 leading-relaxed">
        <span class="lang-en">Perhaps it was moved, or perhaps it never was. Either way, we invite you to return
        to the main residence and continue your exploration from there.</span>
        <span class="lang-id">Mungkin halaman telah dipindahkan, atau mungkin tidak pernah ada. Apa pun itu,
        kami mengundang Anda kembali ke hunian utama dan melanjutkan penjelajahan dari sana.</span>
      </p>
      <a href="/" class="btn btn-outline-gold btn-lg" data-lang-en="Return Home" data-lang-id="Kembali ke Beranda">Return Home</a>
    </div>
  </section>
</Layout>
